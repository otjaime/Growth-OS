  @@index([organizationId])
  @@index([adFitnessScore])
  @@map("product_performance")
}

// ══════════════════════════════════════════════════════════════
// PROACTIVE AD JOBS — Tracks lifecycle of proactively created ads
// ══════════════════════════════════════════════════════════════

enum ProactiveAdStatus {
  PENDING
  GENERATING
  READY
  APPROVED
  PUBLISHED
  TESTING
  WINNER
  PAUSED
  FAILED
}

model ProactiveAdJob {
