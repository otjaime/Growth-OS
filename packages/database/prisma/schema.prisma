// ──────────────────────────────────────────────────────────────
// Growth OS — Prisma Schema
// Full data model: raw layer, staging, marts, orchestration,
// multi-tenancy (Organization / User)
// ──────────────────────────────────────────────────────────────

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ══════════════════════════════════════════════════════════════
// MULTI-TENANCY
// ══════════════════════════════════════════════════════════════

enum Plan {
  FREE
  STARTER
  GROWTH
  SCALE
}

enum UserRole {
  OWNER
  MEMBER
}

model Organization {
  id                   String    @id @default(cuid())
  name                 String
  clerkOrgId           String?   @unique @map("clerk_org_id")
  plan                 Plan      @default(FREE)
  stripeCustomerId     String?   @map("stripe_customer_id")
  stripeSubscriptionId String?   @map("stripe_subscription_id")
  trialEndsAt          DateTime? @map("trial_ends_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  users                User[]
  rawEvents            RawEvent[]
  jobRuns              JobRun[]
  connectorCredentials ConnectorCredential[]
  stgOrders            StgOrder[]
  stgCustomers         StgCustomer[]
  stgSpend             StgSpend[]
  stgTraffic           StgTraffic[]
  stgEmail             StgEmail[]
  dimCampaigns         DimCampaign[]
  dimCustomers         DimCustomer[]
  factOrders           FactOrder[]
  factSpend            FactSpend[]
  factTraffic          FactTraffic[]
  factEmail            FactEmail[]
  cohorts              Cohort[]
  experiments          Experiment[]
  opportunities        Opportunity[]
  growthScenarios      GrowthScenario[]
  metaAdAccounts       MetaAdAccount[]
  metaCampaigns        MetaCampaign[]
  metaAdSets           MetaAdSet[]
  metaAds              MetaAd[]
  metaAdSnapshots      MetaAdSnapshot[]
  diagnoses            Diagnosis[]
  autopilotConfig      AutopilotConfig?
  autopilotActionLogs  AutopilotActionLog[]
  diagnosisFeedback    DiagnosisFeedback[]
  copyVariants         CopyVariant[]
  productPerformance   ProductPerformance[]
  proactiveAdJobs      ProactiveAdJob[]
  @@map("organizations")
}

model User {
  id             String       @id @default(cuid())
  clerkUserId    String       @unique @map("clerk_user_id")
  email          String       @unique
  name           String?
  role           UserRole     @default(MEMBER)
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@index([organizationId])
  @@map("users")
}

// ══════════════════════════════════════════════════════════════
// RAW LAYER
// ══════════════════════════════════════════════════════════════

model RawEvent {
  id             String        @id @default(uuid())
  source         String // shopify | meta | google_ads | ga4
  entity         String // orders | customers | campaigns | insights | sessions
  externalId     String?       @map("external_id")
  cursor         String? // pagination cursor or updated_at watermark
  fetchedAt      DateTime      @default(now()) @map("fetched_at")
  payloadJson    Json          @map("payload_json")
  organizationId String?       @map("organization_id")
  organization   Organization? @relation(fields: [organizationId], references: [id])

  @@index([source, entity])
  @@index([source, entity, externalId])
  @@index([fetchedAt])
  @@index([organizationId])
  @@map("raw_events")
}

model JobRun {
  id             String        @id @default(uuid())
  jobName        String        @map("job_name")
  status         JobStatus     @default(PENDING)
  startedAt      DateTime      @default(now()) @map("started_at")
  finishedAt     DateTime?     @map("finished_at")
  rowsLoaded     Int           @default(0) @map("rows_loaded")
  errorJson      Json?         @map("error_json")
  durationMs     Int?          @map("duration_ms")
  metadata       Json? // extra context: source, entity, cursor range, etc.
  organizationId String?       @map("organization_id")
  organization   Organization? @relation(fields: [organizationId], references: [id])

  @@index([jobName, startedAt])
  @@index([status])
  @@index([organizationId])
  @@map("job_runs")
}

enum JobStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  RETRYING
}

// ══════════════════════════════════════════════════════════════
// CREDENTIAL STORAGE (encrypted at rest)
// ══════════════════════════════════════════════════════════════

model ConnectorCredential {
  id             String        @id @default(uuid())
  connectorType  String        @map("connector_type") // shopify | google | meta
  encryptedData  String        @map("encrypted_data") // AES-GCM encrypted JSON
  iv             String // initialization vector
  authTag        String        @map("auth_tag") // GCM auth tag
  metadata       Json? // non-sensitive config (shop domain, property id, etc.)
  lastSyncAt     DateTime?     @map("last_sync_at")
  lastSyncStatus String?       @map("last_sync_status")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  organizationId String?       @map("organization_id")
  organization   Organization? @relation(fields: [organizationId], references: [id])

  @@unique([connectorType])
  @@index([organizationId])
  @@map("connector_credentials")
}

// ══════════════════════════════════════════════════════════════
// STAGING LAYER
// ══════════════════════════════════════════════════════════════

model StgOrder {
  id             String        @id @default(uuid())
  orderId        String        @unique @map("order_id") // Shopify order ID
  orderDate      DateTime      @map("order_date")
  customerId     String?       @map("customer_id")
  email          String?
  revenueGross   Decimal       @map("revenue_gross") @db.Decimal(12, 2)
  discounts      Decimal       @default(0) @db.Decimal(12, 2)
  refunds        Decimal       @default(0) @db.Decimal(12, 2)
  revenueNet     Decimal       @map("revenue_net") @db.Decimal(12, 2)
  currency       String        @default("USD")
  sourceName     String?       @map("source_name")
  landingSite    String?       @map("landing_site")
  referringSite  String?       @map("referring_site")
  utmSource      String?       @map("utm_source")
  utmMedium      String?       @map("utm_medium")
  utmCampaign    String?       @map("utm_campaign")
  channelRaw     String?       @map("channel_raw")
  region         String?
  lineItemsJson  Json?         @map("line_items_json")
  isNewCustomer  Boolean       @default(false) @map("is_new_customer")
  paymentMethod  String?       @map("payment_method")
  paymentStatus  String?       @map("payment_status")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  organizationId String?       @map("organization_id")
  organization   Organization? @relation(fields: [organizationId], references: [id])

  @@index([orderDate])
  @@index([customerId])
  @@index([organizationId])
  @@map("stg_orders")
}

model StgCustomer {
  id                 String        @id @default(uuid())
  customerId         String        @unique @map("customer_id")
  email              String?
  firstOrderDate     DateTime?     @map("first_order_date")
  acquisitionChannel String?       @map("acquisition_channel")
  region             String?
  totalOrders        Int           @default(0) @map("total_orders")
  totalRevenue       Decimal       @default(0) @map("total_revenue") @db.Decimal(12, 2)
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")
  organizationId     String?       @map("organization_id")
  organization       Organization? @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@map("stg_customers")
}

model StgSpend {
  id              String        @id @default(uuid())
  date            DateTime      @db.Date
  source          String // meta | google_ads
  campaignId      String        @map("campaign_id")
  campaignName    String        @map("campaign_name")
  spend           Decimal       @db.Decimal(12, 2)
  impressions     Int           @default(0)
  clicks          Int           @default(0)
  conversions     Int           @default(0)
  conversionValue Decimal       @default(0) @map("conversion_value") @db.Decimal(12, 2)
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  organizationId  String?       @map("organization_id")
  organization    Organization? @relation(fields: [organizationId], references: [id])

  @@unique([date, source, campaignId])
  @@index([date])
  @@index([organizationId])
  @@map("stg_spend")
}

model StgTraffic {
  id             String        @id @default(uuid())
  date           DateTime      @db.Date
  source         String // ga4
  channelRaw     String?       @map("channel_raw")
  sessions       Int           @default(0)
  pdpViews       Int           @default(0) @map("pdp_views")
  addToCart      Int           @default(0) @map("add_to_cart")
  checkouts      Int           @default(0)
  purchases      Int           @default(0)
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  organizationId String?       @map("organization_id")
  organization   Organization? @relation(fields: [organizationId], references: [id])

  @@unique([date, source, channelRaw])
  @@index([date])
  @@index([organizationId])
  @@map("stg_traffic")
}

model StgEmail {
  id             String        @id @default(uuid())
  date           DateTime      @db.Date
  source         String // klaviyo
  campaignId     String        @map("campaign_id")
  campaignName   String        @map("campaign_name")
  campaignType   String        @map("campaign_type") // campaign | flow
  sends          Int           @default(0)
  opens          Int           @default(0)
  clicks         Int           @default(0)
  bounces        Int           @default(0)
  unsubscribes   Int           @default(0)
  conversions    Int           @default(0)
  revenue        Decimal       @default(0) @db.Decimal(12, 2)
  createdAt      DateTime      @default(now()) @map("created_at")
  organizationId String?       @map("organization_id")
  organization   Organization? @relation(fields: [organizationId], references: [id])

  @@unique([date, source, campaignId], map: "stg_email_date_source_campaign")
  @@index([date])
  @@index([organizationId])
  @@map("stg_email")
}

// ══════════════════════════════════════════════════════════════
// MART / SEMANTIC LAYER — DIMENSIONS
// ══════════════════════════════════════════════════════════════

model DimDate {
  date      DateTime @id @db.Date
  dayOfWeek Int      @map("day_of_week")
  dayName   String   @map("day_name")
  week      Int
  month     Int
  monthName String   @map("month_name")
  quarter   Int
  year      Int
  isWeekend Boolean  @map("is_weekend")

  @@map("dim_date")
}

model DimChannel {
  id   String @id @default(uuid())
  slug String @unique // meta, google, email, organic, affiliate, direct, other
  name String // Meta Ads, Google Ads, Email, Organic, Affiliate, Direct, Other

  factOrders   FactOrder[]
  factSpend    FactSpend[]
  factTraffic  FactTraffic[]
  factEmail    FactEmail[]
  dimCampaigns DimCampaign[]

  @@map("dim_channel")
}

model DimCampaign {
  id             String        @id @default(uuid())
  source         String // meta | google_ads
  campaignId     String        @map("campaign_id")
  campaignName   String        @map("campaign_name")
  channelId      String        @map("channel_id")
  channel        DimChannel    @relation(fields: [channelId], references: [id])
  organizationId String?       @map("organization_id")
  organization   Organization? @relation(fields: [organizationId], references: [id])

  factOrders FactOrder[]
  factSpend  FactSpend[]
  factEmail  FactEmail[]

  @@unique([source, campaignId])
  @@index([organizationId])
  @@map("dim_campaign")
}

model DimCustomer {
  id                 String        @id @default(uuid())
  customerId         String        @unique @map("customer_id")
  firstOrderDate     DateTime?     @map("first_order_date") @db.Date
  acquisitionChannel String?       @map("acquisition_channel")
  region             String?
  isNewCustomer      Boolean       @default(true) @map("is_new_customer")
  cohortMonth        String?       @map("cohort_month") // YYYY-MM
  totalOrders        Int           @default(0) @map("total_orders")
  totalRevenue       Decimal       @default(0) @map("total_revenue") @db.Decimal(12, 2)
  ltv30              Decimal       @default(0) @db.Decimal(12, 2)
  ltv90              Decimal       @default(0) @db.Decimal(12, 2)
  ltv180             Decimal       @default(0) @db.Decimal(12, 2)
  lastOrderDate      DateTime?     @map("last_order_date") @db.Date
  rfmRecency         Int?          @map("rfm_recency")
  rfmFrequency       Int?          @map("rfm_frequency")
  rfmMonetary        Int?          @map("rfm_monetary")
  segment            String?
  organizationId     String?       @map("organization_id")
  organization       Organization? @relation(fields: [organizationId], references: [id])

  factOrders FactOrder[]

  @@index([organizationId])
  @@map("dim_customer")
}

// ══════════════════════════════════════════════════════════════
// MART / SEMANTIC LAYER — FACTS
// ══════════════════════════════════════════════════════════════

model FactOrder {
  id                 String        @id @default(uuid())
  orderId            String        @unique @map("order_id")
  orderDate          DateTime      @map("order_date") @db.Date
  customerId         String?       @map("customer_id")
  customer           DimCustomer?  @relation(fields: [customerId], references: [customerId])
  revenueGross       Decimal       @map("revenue_gross") @db.Decimal(12, 2)
  discounts          Decimal       @default(0) @db.Decimal(12, 2)
  refunds            Decimal       @default(0) @db.Decimal(12, 2)
  revenueNet         Decimal       @map("revenue_net") @db.Decimal(12, 2)
  cogs               Decimal       @default(0) @db.Decimal(12, 2)
  shippingCost       Decimal       @default(0) @map("shipping_cost") @db.Decimal(12, 2)
  opsCost            Decimal       @default(0) @map("ops_cost") @db.Decimal(12, 2)
  contributionMargin Decimal       @default(0) @map("contribution_margin") @db.Decimal(12, 2)
  channelId          String?       @map("channel_id")
  channel            DimChannel?   @relation(fields: [channelId], references: [id])
  campaignId         String?       @map("campaign_id")
  campaign           DimCampaign?  @relation(fields: [campaignId], references: [id])
  category           String?
  region             String?
  isNewCustomer      Boolean       @default(false) @map("is_new_customer")
  paymentMethod      String?       @map("payment_method")
  paymentStatus      String?       @map("payment_status")
  organizationId     String?       @map("organization_id")
  organization       Organization? @relation(fields: [organizationId], references: [id])

  @@index([orderDate])
  @@index([channelId])
  @@index([customerId])
  @@index([organizationId])
  @@map("fact_orders")
}

model FactSpend {
  id             String        @id @default(uuid())
  date           DateTime      @db.Date
  channelId      String        @map("channel_id")
  channel        DimChannel    @relation(fields: [channelId], references: [id])
  campaignId     String?       @map("campaign_id")
  campaign       DimCampaign?  @relation(fields: [campaignId], references: [id])
  spend          Decimal       @db.Decimal(12, 2)
  impressions    Int           @default(0)
  clicks         Int           @default(0)
  organizationId String?       @map("organization_id")
  organization   Organization? @relation(fields: [organizationId], references: [id])

  @@unique([date, channelId, campaignId])
  @@index([date])
  @@index([organizationId])
  @@map("fact_spend")
}

model FactTraffic {
  id             String        @id @default(uuid())
  date           DateTime      @db.Date
  channelId      String        @map("channel_id")
  channel        DimChannel    @relation(fields: [channelId], references: [id])
  sessions       Int           @default(0)
  pdpViews       Int           @default(0) @map("pdp_views")
  addToCart      Int           @default(0) @map("add_to_cart")
  checkouts      Int           @default(0)
  purchases      Int           @default(0)
  organizationId String?       @map("organization_id")
  organization   Organization? @relation(fields: [organizationId], references: [id])

  @@unique([date, channelId])
  @@index([date])
  @@index([organizationId])
  @@map("fact_traffic")
}

model FactEmail {
  id             String        @id @default(uuid())
  date           DateTime      @db.Date
  channelId      String        @map("channel_id")
  channel        DimChannel    @relation(fields: [channelId], references: [id])
  campaignId     String?       @map("campaign_id")
  campaign       DimCampaign?  @relation(fields: [campaignId], references: [id])
  sends          Int           @default(0)
  opens          Int           @default(0)
  clicks         Int           @default(0)
  bounces        Int           @default(0)
  unsubscribes   Int           @default(0)
  conversions    Int           @default(0)
  revenue        Decimal       @default(0) @db.Decimal(12, 2)
  openRate       Decimal?      @map("open_rate") @db.Decimal(5, 4)
  clickRate      Decimal?      @map("click_rate") @db.Decimal(5, 4)
  conversionRate Decimal?      @map("conversion_rate") @db.Decimal(5, 4)
  createdAt      DateTime      @default(now()) @map("created_at")
  organizationId String?       @map("organization_id")
  organization   Organization? @relation(fields: [organizationId], references: [id])

  @@unique([date, channelId, campaignId], map: "fact_email_date_channel_campaign")
  @@index([date])
  @@index([organizationId])
  @@map("fact_email")
}

model Cohort {
  id             String        @id @default(uuid())
  cohortMonth    String        @unique @map("cohort_month") // YYYY-MM
  cohortSize     Int           @map("cohort_size")
  d7Retention    Decimal       @default(0) @map("d7_retention") @db.Decimal(5, 4)
  d30Retention   Decimal       @default(0) @map("d30_retention") @db.Decimal(5, 4)
  d60Retention   Decimal       @default(0) @map("d60_retention") @db.Decimal(5, 4)
  d90Retention   Decimal       @default(0) @map("d90_retention") @db.Decimal(5, 4)
  ltv30          Decimal       @default(0) @db.Decimal(12, 2)
  ltv90          Decimal       @default(0) @db.Decimal(12, 2)
  ltv180         Decimal       @default(0) @db.Decimal(12, 2)
  paybackDays    Int?          @map("payback_days")
  avgCac         Decimal?      @default(0) @map("avg_cac") @db.Decimal(12, 2)
  organizationId String?       @map("organization_id")
  organization   Organization? @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@map("cohorts")
}

// ══════════════════════════════════════════════════════════════
// EXPERIMENTATION
// ══════════════════════════════════════════════════════════════

enum ExperimentType {
  CRO
  CREATIVE
  PRICING
  LIFECYCLE
  LANDING
  OTHER
}

enum ExperimentStatus {
  IDEA
  BACKLOG
  RUNNING
  COMPLETED
  ARCHIVED
}

model Experiment {
  id            String           @id @default(uuid())
  name          String
  hypothesis    String           @db.Text
  status        ExperimentStatus @default(IDEA)
  channel       String?
  primaryMetric String           @map("primary_metric")
  targetLift    Float?           @map("target_lift")

  // ICE scoring
  impact     Int?
  confidence Int?
  ease       Int?
  iceScore   Float? @map("ice_score")

  startDate DateTime? @map("start_date")
  endDate   DateTime? @map("end_date")
  result    String?   @db.Text
  learnings String?   @db.Text
  nextSteps String?   @map("next_steps") @db.Text

  // A/B test variant metadata
  controlName String? @map("control_name")
  variantName String? @map("variant_name")

  // A/B test sample data (user-provided)
  controlSampleSize  Int? @map("control_sample_size")
  variantSampleSize  Int? @map("variant_sample_size")
  controlConversions Int? @map("control_conversions")
  variantConversions Int? @map("variant_conversions")

  // A/B test computed results (auto-computed on save)
  controlRate        Float?   @map("control_rate")
  variantRate        Float?   @map("variant_rate")
  absoluteLift       Float?   @map("absolute_lift")
  relativeLift       Float?   @map("relative_lift")
  pValue             Float?   @map("p_value")
  confidenceLevel    Float?   @map("confidence_level")
  isSignificant      Boolean? @map("is_significant")
  confidenceInterval Json?    @map("confidence_interval")
  verdict            String?

  // Scorecard fields
  experimentType    ExperimentType? @map("experiment_type")
  expectedImpactUsd Float?          @map("expected_impact_usd")
  guardrailMetrics  Json?           @map("guardrail_metrics")
  targetSegment     String?         @map("target_segment")

  organizationId String?       @map("organization_id")
  organization   Organization? @relation(fields: [organizationId], references: [id])

  metrics ExperimentMetric[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([channel])
  @@index([organizationId])
  @@map("experiments")
}

model ExperimentMetric {
  id           String     @id @default(uuid())
  experimentId String     @map("experiment_id")
  experiment   Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  date         DateTime
  metricName   String     @map("metric_name")
  value        Float
  notes        String?

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([experimentId, date, metricName], map: "experiment_date_metric")
  @@map("experiment_metrics")
}

// ══════════════════════════════════════════════════════════════
// AI SUGGESTION ENGINE
// ══════════════════════════════════════════════════════════════

enum OpportunityType {
  EFFICIENCY_DROP
  CAC_SPIKE
  RETENTION_DECLINE
  FUNNEL_LEAK
  GROWTH_PLATEAU
  CHANNEL_IMBALANCE
  QUICK_WIN
}

enum OpportunityStatus {
  NEW
  REVIEWED
  ACTED
  DISMISSED
}

enum SuggestionType {
  AI_GENERATED
  PLAYBOOK_MATCH
  RULE_BASED
}

enum SuggestionStatus {
  PENDING
  APPROVED
  REJECTED
  PROMOTED
}

enum FeedbackAction {
  APPROVE
  REJECT
  MODIFY
  PROMOTE
}

model Opportunity {
  id             String            @id @default(uuid())
  type           OpportunityType
  title          String
  description    String            @db.Text
  priority       Int               @default(50)
  status         OpportunityStatus @default(NEW)
  signalsJson    Json              @map("signals_json")
  suggestions    Suggestion[]
  organizationId String?           @map("organization_id")
  organization   Organization?     @relation(fields: [organizationId], references: [id])
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  @@index([status])
  @@index([type])
  @@index([organizationId])
  @@map("opportunities")
}

model Suggestion {
  id                  String               @id @default(uuid())
  opportunityId       String               @map("opportunity_id")
  opportunity         Opportunity          @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  type                SuggestionType       @default(AI_GENERATED)
  title               String
  hypothesis          String               @db.Text
  suggestedChannel    String?              @map("suggested_channel")
  suggestedMetric     String?              @map("suggested_metric")
  suggestedTargetLift Float?               @map("suggested_target_lift")
  impactScore         Int?                 @map("impact_score")
  confidenceScore     Int?                 @map("confidence_score")
  effortScore         Int?                 @map("effort_score")
  riskScore           Int?                 @map("risk_score")
  reasoning           String?              @db.Text
  playbookRef         String?              @map("playbook_ref")
  driverAnalysis      String?              @map("driver_analysis") @db.Text
  actionsJson         Json?                @map("actions_json")
  status              SuggestionStatus     @default(PENDING)
  feedback            SuggestionFeedback[]
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")

  @@index([opportunityId])
  @@index([status])
  @@map("suggestions")
}

model SuggestionFeedback {
  id                   String         @id @default(uuid())
  suggestionId         String         @map("suggestion_id")
  suggestion           Suggestion     @relation(fields: [suggestionId], references: [id], onDelete: Cascade)
  action               FeedbackAction
  notes                String?        @db.Text
  promotedExperimentId String?        @map("promoted_experiment_id")
  createdAt            DateTime       @default(now()) @map("created_at")

  @@index([suggestionId])
  @@map("suggestion_feedback")
}

// ══════════════════════════════════════════════════════════════
// GROWTH MODEL / SCENARIO PLANNING
// ══════════════════════════════════════════════════════════════

model GrowthScenario {
  id          String  @id @default(uuid())
  name        String
  description String? @db.Text
  isBaseline  Boolean @default(false) @map("is_baseline")

  // Input assumptions
  monthlyBudget        Float @map("monthly_budget")
  targetCac            Float @map("target_cac")
  expectedCvr          Float @map("expected_cvr")
  avgOrderValue        Float @map("avg_order_value")
  cogsPercent          Float @map("cogs_percent")
  monthlyTraffic       Int?  @map("monthly_traffic")
  returnRate           Float @default(0) @map("return_rate")
  avgOrdersPerCustomer Float @default(1) @map("avg_orders_per_customer")
  horizonMonths        Int   @default(6) @map("horizon_months")

  // Computed outputs (stored for quick listing)
  projectedRevenue            Float @map("projected_revenue")
  projectedOrders             Int   @map("projected_orders")
  projectedCustomers          Int   @map("projected_customers")
  projectedRoas               Float @map("projected_roas")
  projectedMer                Float @map("projected_mer")
  projectedLtv                Float @map("projected_ltv")
  projectedContributionMargin Float @map("projected_contribution_margin")
  breakEvenMonth              Int?  @map("break_even_month")

  organizationId String?       @map("organization_id")
  organization   Organization? @relation(fields: [organizationId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([organizationId])
  @@map("growth_scenarios")
}

// ══════════════════════════════════════════════════════════════
// META ADS — AD-LEVEL CREATIVE DATA
// ══════════════════════════════════════════════════════════════

enum MetaAdStatus {
  ACTIVE
  PAUSED
  DELETED
  ARCHIVED
}

model MetaAdAccount {
  id             String        @id @default(cuid())
  organizationId String        @map("organization_id")
  organization   Organization  @relation(fields: [organizationId], references: [id])
  adAccountId    String        @map("ad_account_id") // act_xxx
  name           String
  currency       String        @default("USD")
  timezone       String        @default("America/New_York")
  status         MetaAdStatus  @default(ACTIVE)
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  campaigns MetaCampaign[]
  adSets    MetaAdSet[]
  ads       MetaAd[]

  @@unique([organizationId, adAccountId])
  @@index([organizationId])
  @@map("meta_ad_accounts")
}

model MetaCampaign {
  id             String        @id @default(cuid())
  organizationId String        @map("organization_id")
  organization   Organization  @relation(fields: [organizationId], references: [id])
  accountId      String        @map("account_id")
  account        MetaAdAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  campaignId     String        @map("campaign_id") // Meta external ID
  name           String
  status         MetaAdStatus  @default(ACTIVE)
  objective      String?
  dailyBudget    Decimal?      @map("daily_budget") @db.Decimal(12, 2)
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  adSets MetaAdSet[]
  ads    MetaAd[]

  @@unique([organizationId, campaignId])
  @@index([organizationId])
  @@index([accountId])
  @@map("meta_campaigns")
}

model MetaAdSet {
  id             String        @id @default(cuid())
  organizationId String        @map("organization_id")
  organization   Organization  @relation(fields: [organizationId], references: [id])
  accountId      String        @map("account_id")
  account        MetaAdAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  campaignId     String        @map("campaign_id")
  campaign       MetaCampaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  adSetId        String        @map("ad_set_id") // Meta external ID
  name           String
  status         MetaAdStatus  @default(ACTIVE)
  dailyBudget    Decimal?      @map("daily_budget") @db.Decimal(12, 2)
  targetingJson  Json?         @map("targeting_json")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  ads MetaAd[]

  @@unique([organizationId, adSetId])
  @@index([organizationId])
  @@index([campaignId])
  @@map("meta_ad_sets")
}

model MetaAd {
  id             String        @id @default(cuid())
  organizationId String        @map("organization_id")
  organization   Organization  @relation(fields: [organizationId], references: [id])
  accountId      String        @map("account_id")
  account        MetaAdAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  campaignId     String        @map("campaign_id")
  campaign       MetaCampaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  adSetId        String        @map("ad_set_id")
  adSet          MetaAdSet     @relation(fields: [adSetId], references: [id], onDelete: Cascade)
  adId           String        @map("ad_id") // Meta external ID
  name           String
  status         MetaAdStatus  @default(ACTIVE)

  // Creative fields
  headline       String?
  primaryText    String?       @map("primary_text") @db.Text
  description    String?       @db.Text
  imageUrl       String?       @map("image_url")
  thumbnailUrl   String?       @map("thumbnail_url")
  callToAction   String?       @map("call_to_action")
  creativeType   String?       @map("creative_type") // IMAGE, VIDEO, CAROUSEL

  // 7-day metrics (current window)
  spend7d        Decimal       @default(0) @map("spend_7d") @db.Decimal(12, 2)
  impressions7d  Int           @default(0) @map("impressions_7d")
  clicks7d       Int           @default(0) @map("clicks_7d")
  conversions7d  Int           @default(0) @map("conversions_7d")
  revenue7d      Decimal       @default(0) @map("revenue_7d") @db.Decimal(12, 2)
  roas7d         Decimal?      @map("roas_7d") @db.Decimal(8, 4)
  ctr7d          Decimal?      @map("ctr_7d") @db.Decimal(8, 6)
  cpc7d          Decimal?      @map("cpc_7d") @db.Decimal(12, 2)
  frequency7d    Decimal?      @map("frequency_7d") @db.Decimal(8, 4)

  // 14-day metrics (previous window for trend comparison)
  spend14d       Decimal       @default(0) @map("spend_14d") @db.Decimal(12, 2)
  impressions14d Int           @default(0) @map("impressions_14d")
  clicks14d      Int           @default(0) @map("clicks_14d")
  conversions14d Int           @default(0) @map("conversions_14d")
  revenue14d     Decimal       @default(0) @map("revenue_14d") @db.Decimal(12, 2)
  roas14d        Decimal?      @map("roas_14d") @db.Decimal(8, 4)
  ctr14d         Decimal?      @map("ctr_14d") @db.Decimal(8, 6)
  cpc14d         Decimal?      @map("cpc_14d") @db.Decimal(12, 2)
  frequency14d   Decimal?      @map("frequency_14d") @db.Decimal(8, 4)

  lastSyncAt     DateTime?     @map("last_sync_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  diagnoses      Diagnosis[]
  variants       AdVariant[]
  snapshots      MetaAdSnapshot[]

  @@unique([organizationId, adId])
  @@index([organizationId])
  @@index([campaignId])
  @@index([adSetId])
  @@index([status])
  @@map("meta_ads")
}

// ══════════════════════════════════════════════════════════════
// DIAGNOSIS ENGINE — Ad-level automated diagnosis
// ══════════════════════════════════════════════════════════════

enum DiagnosisAction {
  GENERATE_COPY_VARIANTS
  PAUSE_AD
  REACTIVATE_AD
  INCREASE_BUDGET
  DECREASE_BUDGET
  REFRESH_CREATIVE
  DUPLICATE_AD_SET
  NONE
}

enum DiagnosisStatus {
  PENDING
  APPROVED
  EXECUTED
  DISMISSED
  EXPIRED
}

enum DiagnosisSeverity {
  CRITICAL
  WARNING
  INFO
}

model Diagnosis {
  id               String             @id @default(cuid())
  organizationId   String             @map("organization_id")
  organization     Organization       @relation(fields: [organizationId], references: [id])
  adId             String             @map("ad_id")
  ad               MetaAd             @relation(fields: [adId], references: [id], onDelete: Cascade)
  ruleId           String             @map("rule_id") // e.g. "creative_fatigue", "roas_negative"
  severity         DiagnosisSeverity
  title            String
  message          String             @db.Text
  actionType       DiagnosisAction    @map("action_type")
  status           DiagnosisStatus    @default(PENDING)
  suggestedValue   Json?              @map("suggested_value") // e.g. { newBudget: 500 }
  executedAt       DateTime?          @map("executed_at")
  executionResult  Json?              @map("execution_result")
  aiInsight        Json?              @map("ai_insight")       // cached AI analysis (rootCause, recommendations)
  aiInsightAt      DateTime?          @map("ai_insight_at")    // when AI insight was last generated
  confidence       Int?             // 0-100 confidence score for this diagnosis
  expiresAt        DateTime           @map("expires_at")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  variants         AdVariant[]

  @@unique([organizationId, adId, ruleId])
  @@index([organizationId])
  @@index([adId])
  @@index([status])
  @@index([severity])
  @@map("diagnoses")
}

// ══════════════════════════════════════════════════════════════
// AD VARIANTS — AI-generated copy alternatives
// ══════════════════════════════════════════════════════════════

enum VariantStatus {
  DRAFT
  APPROVED
  PUBLISHED
  REJECTED
  WINNER
  LOSER
}

model AdVariant {
  id             String        @id @default(cuid())
  diagnosisId    String        @map("diagnosis_id")
  diagnosis      Diagnosis     @relation(fields: [diagnosisId], references: [id], onDelete: Cascade)
  adId           String        @map("ad_id")
  ad             MetaAd        @relation(fields: [adId], references: [id], onDelete: Cascade)
  angle          String        // 'benefit', 'pain_point', 'urgency'
  headline       String
  primaryText    String        @map("primary_text") @db.Text
  description    String?
  status         VariantStatus @default(DRAFT)
  metaAdId       String?       @map("meta_ad_id") // external Meta ad ID once published
  // Performance tracking (populated after publishing)
  spend          Decimal?      @db.Decimal(12, 2)
  impressions    Int?
  clicks         Int?
  conversions    Int?
  revenue        Decimal?      @db.Decimal(12, 2)
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  @@index([diagnosisId])
  @@index([adId])
  @@index([status])
  @@map("ad_variants")
}

// ══════════════════════════════════════════════════════════════
// META AD SNAPSHOTS — Daily metric history for trend analysis
// ══════════════════════════════════════════════════════════════

model MetaAdSnapshot {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id])
  adId           String       @map("ad_id")
  ad             MetaAd       @relation(fields: [adId], references: [id], onDelete: Cascade)
  date           DateTime     @db.Date
  spend          Decimal      @default(0) @db.Decimal(12, 2)
  impressions    Int          @default(0)
  clicks         Int          @default(0)
  conversions    Int          @default(0)
  revenue        Decimal      @default(0) @db.Decimal(12, 2)
  roas           Decimal?     @db.Decimal(8, 4)
  ctr            Decimal?     @db.Decimal(8, 6)
  cpc            Decimal?     @db.Decimal(12, 2)
  frequency      Decimal?     @db.Decimal(8, 4)
  createdAt      DateTime     @default(now()) @map("created_at")

  @@unique([organizationId, adId, date])
  @@index([adId, date])
  @@index([organizationId, date])
  @@map("meta_ad_snapshots")
}

// ══════════════════════════════════════════════════════════════
// AUTOPILOT CONFIGURATION — Per-org targets, modes, and limits
// ══════════════════════════════════════════════════════════════

model AutopilotConfig {
  id                   String       @id @default(cuid())
  organizationId       String       @unique @map("organization_id")
  organization         Organization @relation(fields: [organizationId], references: [id])

  // Automation mode: monitor (alerts only) | suggest (approval needed) | auto (auto-execute)
  mode                 String       @default("suggest")

  // Performance targets
  targetRoas           Decimal?     @map("target_roas") @db.Decimal(8, 4)
  maxCpa               Decimal?     @map("max_cpa") @db.Decimal(12, 2)
  dailyBudgetCap       Decimal?     @map("daily_budget_cap") @db.Decimal(12, 2)

  // Safety limits for auto-mode
  maxBudgetIncreasePct Int          @default(50) @map("max_budget_increase_pct")
  maxActionsPerDay     Int          @default(10) @map("max_actions_per_day")
  minSpendBeforeAction Decimal      @default(50) @map("min_spend_before_action") @db.Decimal(12, 2)
  minConfidence        Int          @default(70) @map("min_confidence") // Minimum confidence for auto-execution

  // Execution window
  executionWindowStart Int          @default(9) @map("execution_window_start")
  executionWindowEnd   Int          @default(17) @map("execution_window_end")
  executionTimezone    String       @default("America/New_York") @map("execution_timezone")

  // Daily guardrails
  dailyBudgetChangeCap Decimal?     @map("daily_budget_change_cap") @db.Decimal(12, 2)

  // Circuit breaker
  circuitBreakerEnabled  Boolean    @default(true) @map("circuit_breaker_enabled")
  circuitBreakerWindowH  Int        @default(48) @map("circuit_breaker_window_hours")
  circuitBreakerThreshold Int       @default(3) @map("circuit_breaker_threshold")
  circuitBreakerTrippedAt DateTime? @map("circuit_breaker_tripped_at")

  // Rule tuner: learned threshold overrides from feedback patterns
  ruleOverrides        Json?        @map("rule_overrides")

  // Notification preferences
  slackWebhookUrl      String?      @map("slack_webhook_url")
  notifyOnCritical     Boolean      @default(true) @map("notify_on_critical")
  notifyOnAutoAction   Boolean      @default(true) @map("notify_on_auto_action")
  notifyOnPendingApproval Boolean   @default(true) @map("notify_on_pending_approval")

  // Proactive ad settings
  proactiveEnabled       Boolean    @default(false) @map("proactive_enabled")
  maxProactiveAdsPerMonth Int       @default(5) @map("max_proactive_ads_per_month")
  minAdFitnessScore      Int        @default(60) @map("min_ad_fitness_score")
  maxTestRounds          Int        @default(3) @map("max_test_rounds")
  proactiveDefaultBudget Decimal?   @map("proactive_default_budget") @db.Decimal(12, 2)
  useAIImages            Boolean    @default(false) @map("use_ai_images")

  createdAt            DateTime     @default(now()) @map("created_at")
  updatedAt            DateTime     @updatedAt @map("updated_at")

  @@map("autopilot_configs")
}

// ══════════════════════════════════════════════════════════════
// AUTOPILOT ACTION LOG — Audit trail for all actions (manual + auto)
// ══════════════════════════════════════════════════════════════

model AutopilotActionLog {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id])
  diagnosisId    String?      @map("diagnosis_id")
  actionType     String       @map("action_type")
  triggeredBy    String       @map("triggered_by") // user | auto | schedule
  targetEntity   String       @map("target_entity") // ad | adset | campaign
  targetId       String       @map("target_id")
  targetName     String       @map("target_name")
  beforeValue    Json?        @map("before_value")
  afterValue     Json?        @map("after_value")
  success        Boolean
  errorMessage   String?      @map("error_message")
  rollbackOfId   String?      @map("rollback_of_id")
  undoneAt       DateTime?    @map("undone_at")
  undoneByLogId  String?      @map("undone_by_log_id")
  createdAt      DateTime     @default(now()) @map("created_at")

  @@index([organizationId, createdAt])
  @@index([targetId])
  @@map("autopilot_action_logs")
}

// ══════════════════════════════════════════════════════════════
// DIAGNOSIS FEEDBACK — Tracks approve/dismiss patterns per rule
// ══════════════════════════════════════════════════════════════

model DiagnosisFeedback {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id])
  ruleId         String       @map("rule_id")
  action         String       // APPROVED | DISMISSED | EXPIRED | AUTO_EXECUTED
  diagnosisId    String?      @map("diagnosis_id")
  confidence     Int?         // confidence score at time of action
  createdAt      DateTime     @default(now()) @map("created_at")

  @@index([organizationId, ruleId])
  @@index([ruleId, action])
  @@map("diagnosis_feedback")
}

// ══════════════════════════════════════════════════════════════
// COPY VARIANTS — Tracks AI-generated ad copy variants lifecycle
// ══════════════════════════════════════════════════════════════

model CopyVariant {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id])
  diagnosisId    String       @map("diagnosis_id")
  originalAdId   String       @map("original_ad_id")
  createdAdId    String?      @map("created_ad_id")
  angle          String       // benefit | pain_point | urgency
  headline       String
  primaryText    String       @map("primary_text") @db.Text
  description    String?
  status         String       @default("DRAFT") // DRAFT | APPROVED | REJECTED | ACTIVE | WINNER | LOSER
  spend          Decimal?     @db.Decimal(12, 2)
  roas           Decimal?     @db.Decimal(8, 4)
  ctr            Decimal?     @db.Decimal(8, 6)
  conversions    Int?
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@index([diagnosisId])
  @@index([organizationId, status])
  @@map("copy_variants")
}

// ══════════════════════════════════════════════════════════════
// APP SETTINGS (persistent key-value store)
// ══════════════════════════════════════════════════════════════

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

// ══════════════════════════════════════════════════════════════
// PRODUCT PERFORMANCE — Aggregated product-level analytics
// ══════════════════════════════════════════════════════════════

model ProductPerformance {
  id                String        @id @default(cuid())
  organizationId    String?       @map("organization_id")
  organization      Organization? @relation(fields: [organizationId], references: [id])
  productTitle      String        @map("product_title")
  productType       String        @map("product_type")
  unitsSold30d      Int           @default(0) @map("units_sold_30d")
  revenue30d        Decimal       @default(0) @map("revenue_30d") @db.Decimal(12, 2)
  orderCount30d     Int           @default(0) @map("order_count_30d")
