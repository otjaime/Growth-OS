  estimatedMargin   Decimal       @default(0) @map("estimated_margin") @db.Decimal(5, 4)
  grossProfit30d    Decimal       @default(0) @map("gross_profit_30d") @db.Decimal(12, 2)
  avgDailyUnits     Decimal       @default(0) @map("avg_daily_units") @db.Decimal(8, 2)
  repeatBuyerPct    Decimal       @default(0) @map("repeat_buyer_pct") @db.Decimal(5, 4)
  adFitnessScore    Decimal?      @map("ad_fitness_score") @db.Decimal(5, 2)
  shopifyProductId  String?       @map("shopify_product_id")
  imageUrl          String?       @map("image_url")
  productUrl        String?       @map("product_url")
  description       String?       @db.Text
  lastComputedAt    DateTime      @default(now()) @map("last_computed_at")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

