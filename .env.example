# ──────────────────────────────────────────────
# Growth OS — Environment Variables
# Copy to .env and fill in real values
# ──────────────────────────────────────────────

# ── Mode ──
# Set to "true" to use mock connectors (no real credentials needed)
DEMO_MODE=true

# ── Database ──
DATABASE_URL=postgresql://growthuser:growthpass@localhost:5432/growth_os
POSTGRES_USER=growthuser
POSTGRES_PASSWORD=growthpass
POSTGRES_DB=growth_os

# ── Redis ──
REDIS_URL=redis://localhost:6379

# ── Encryption (for storing OAuth tokens at rest) ──
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-char-hex-key-here

# ── API Server ──
API_PORT=4000
API_HOST=0.0.0.0
# Public URL for OAuth callbacks (set to your deployed API URL in production)
PUBLIC_API_URL=http://localhost:4000

# ── Frontend ──
NEXT_PUBLIC_API_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000

# ── Auth (legacy simple auth — used when Clerk is not configured) ──
# ⚠️  CHANGE ALL VALUES BELOW before deploying!
AUTH_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
AUTH_USERNAME=admin
AUTH_PASSWORD=CHANGE_ME_use_a_strong_password

# ── Clerk Auth (recommended for production) ──
# Sign up at https://clerk.com and create an application
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# JWKS URL — auto-derived from publishable key if not set
# CLERK_JWKS_URL=https://your-clerk-instance.clerk.accounts.dev/.well-known/jwks.json

# ── Stripe Billing ──
# Get keys at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Create products+prices in Stripe, then paste the price IDs here
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_SCALE=

# ── OpenAI (for AI features: WBR, Ask, Copy Generation, Suggestions) ──
OPENAI_API_KEY=

# ── Slack Notifications (optional) ──
SLACK_WEBHOOK_URL=

# ── Shopify ──
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxx

# ── Google OAuth (covers Google Ads + GA4) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_DEVELOPER_TOKEN=
GA4_PROPERTY_ID=

# ── Meta (Facebook Ads) ──
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=act_xxxxxxxxxx

# ── Scheduler ──
# Auto-sync interval in milliseconds (default: 1 hour)
SYNC_INTERVAL_MS=3600000
BACKFILL_DAYS=90

# ── Demo Seed ──
DEMO_SEED=42
DEMO_DAYS=180
